# Server
NODE_ENV=production
PORT=3000

# Database
STOCK_DB_PASSWORD=<generate: openssl rand -base64 32>
DATABASE_URL=postgresql://stockuser:${STOCK_DB_PASSWORD}@stock-db:5432/stockplatform

# Auth
STOCK_JWT_SECRET=<generate: openssl rand -base64 48>
JWT_EXPIRY=7d
USER1_USERNAME=harshil
USER1_PASSWORD=<password>
USER1_DISPLAY_NAME=Harshil
USER2_USERNAME=guest
USER2_PASSWORD=<password>
USER2_DISPLAY_NAME=Guest

# File Uploads
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=10
